generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────────────

enum Role {
  STUDENT
  ADVISOR
  STAFF
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum AcademicLevel {
  BACHELOR
  MASTER
  PHD
}

enum RegistrationStatus {
  PENDING_APPROVAL
  REJECTED
  ACTIVE
  SUSPENDED
}

enum VisaStatus {
  ACTIVE
  EXPIRED
  PENDING
  CANCELLED
}

enum RequestStatus {
  PENDING
  FORWARDED_TO_ADVISOR
  ADVISOR_APPROVED
  ADVISOR_REJECTED
  STAFF_APPROVED
  STAFF_REJECTED
  FORWARDED_TO_DEAN
  DEAN_APPROVED
  DEAN_REJECTED
  CANCELLED
}

enum DocumentType {
  PASSPORT_COPY
  VISA_COPY
  TRANSCRIPT
  INSURANCE
  ENROLLMENT_CERTIFICATE
  PHOTO
  WORK_PERMIT
  OTHER
}

enum InterserviceStatus {
  NOT_SUBMITTED
  PENDING
  APPROVED
  REJECTED
}

enum NotificationType {
  VISA_ALERT
  REGISTRATION
  REQUEST_UPDATE
  DOCUMENT_REQUIRED
  GENERAL
}

// ─────────────────────────────────────────────────────
// USER & AUTH
// ─────────────────────────────────────────────────────

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  googleId  String?  @unique
  name      String
  image     String?
  role      Role?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  student       Student?
  advisor       Advisor?
  auditLogs     AuditLog[]
  notifications Notification[]

  @@map("users")
}

// ─────────────────────────────────────────────────────
// STUDENT
// ─────────────────────────────────────────────────────

model Student {
  id        Int     @id @default(autoincrement())
  userId    Int     @unique
  studentId String? @unique

  // Names (EN only, with middle name)
  titleEn       String?
  firstNameEn   String?
  middleNameEn  String?
  lastNameEn    String?

  // Personal info
  dateOfBirth DateTime?
  gender      Gender?
  nationality String?
  religion    String?
  homeCountry String?

  // Contact & address
  email               String?
  phone               String?
  addressInThailand   String?  @db.Text
  homeAddress         String?  @db.Text

  // Emergency contact
  emergencyContact  String?
  emergencyEmail    String?
  emergencyPhone    String?
  emergencyRelation String?

  // Academic info (filled by staff at Phase 2 completion)
  faculty            String?
  program            String?
  level              AcademicLevel?
  enrollmentDate     DateTime?
  expectedGraduation DateTime?
  academicStatus     String?
  scholarship        String?
  advisorId          Int?

  registrationStatus RegistrationStatus @default(PENDING_APPROVAL)
  registrationStep   Int                @default(0)
  rejectionReason    String?            @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user               User                @relation(fields: [userId], references: [id])
  advisor            Advisor?            @relation(fields: [advisorId], references: [id])
  passports          Passport[]
  visas              Visa[]
  healthInsurances   HealthInsurance[]
  dependents         Dependent[]
  documents          Document[]
  requests           Request[]
  visaRenewals       VisaRenewal[]
  interserviceChecks InterserviceCheck[]
  generatedDocuments GeneratedDocument[]

  @@map("students")
}

// ─────────────────────────────────────────────────────
// ADVISOR
// ─────────────────────────────────────────────────────

model Advisor {
  id          Int     @id @default(autoincrement())
  userId      Int     @unique
  titleTh     String?
  firstNameTh String?
  lastNameTh  String?
  titleEn     String?
  firstNameEn String?
  lastNameEn  String?
  nationality String?
  phone       String?
  faculty     String?

  workPermitNumber  String?
  workPermitIssue   DateTime?
  workPermitExpiry  DateTime?
  workPermitFileUrl String?

  isDean    Boolean  @default(false)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user     User      @relation(fields: [userId], references: [id])
  students Student[]

  @@map("advisors")
}

// ─────────────────────────────────────────────────────
// PASSPORT
// ─────────────────────────────────────────────────────

model Passport {
  id             Int      @id @default(autoincrement())
  studentId      Int
  passportNumber String
  issuingCountry String
  issueDate      DateTime
  expiryDate     DateTime
  placeOfIssue   String?
  mrzLine1       String?
  mrzLine2       String?
  imageUrl       String?
  isVerified     Boolean  @default(false)
  isCurrent      Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@map("passports")
}

// ─────────────────────────────────────────────────────
// VISA
// ─────────────────────────────────────────────────────

model Visa {
  id             Int        @id @default(autoincrement())
  studentId      Int
  visaNumber     String?
  visaType       String
  status         VisaStatus @default(ACTIVE)
  issuingCountry String
  issuingPlace   String?
  issueDate      DateTime
  expiryDate     DateTime
  entries        String?
  remarks        String?    @db.Text
  imageUrl       String?
  isCurrent      Boolean    @default(true)
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@map("visas")
}

// ─────────────────────────────────────────────────────
// HEALTH INSURANCE
// ─────────────────────────────────────────────────────

model HealthInsurance {
  id           Int      @id @default(autoincrement())
  studentId    Int
  provider     String
  policyNumber String?
  coverageType String?
  startDate    DateTime
  expiryDate   DateTime
  fileUrl      String?
  isCurrent    Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@map("health_insurances")
}

// ─────────────────────────────────────────────────────
// DEPENDENT
// ─────────────────────────────────────────────────────

model Dependent {
  id           Int    @id @default(autoincrement())
  studentId    Int
  relationship String

  firstNameEn String
  lastNameEn  String
  firstNameTh String?
  lastNameTh  String?
  dateOfBirth DateTime
  gender      Gender
  nationality String

  passportNumber   String?
  passportExpiry   DateTime?
  passportImageUrl String?
  visaType         String?
  visaExpiry       DateTime?
  visaImageUrl     String?
  visaStatus       VisaStatus @default(ACTIVE)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  student   Student    @relation(fields: [studentId], references: [id], onDelete: Cascade)
  documents Document[]

  @@map("dependents")
}

// ─────────────────────────────────────────────────────
// DOCUMENT
// ─────────────────────────────────────────────────────

model Document {
  id           Int          @id @default(autoincrement())
  studentId    Int?
  dependentId  Int?
  documentType DocumentType @default(OTHER)
  name         String
  description  String?
  fileUrl      String
  fileType     String
  fileSize     Int
  uploadedBy   Int

  uploadedAt DateTime @default(now())
  updatedAt  DateTime @updatedAt

  student   Student?   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  dependent Dependent? @relation(fields: [dependentId], references: [id], onDelete: Cascade)

  @@map("documents")
}

// ─────────────────────────────────────────────────────
// DOCUMENT TEMPLATE
// ─────────────────────────────────────────────────────

model DocumentTemplate {
  id          Int     @id @default(autoincrement())
  name        String
  description String?
  body        String  @db.LongText  // HTML content with {{variable}} placeholders
  variables   String? @db.Text      // JSON array of variable tokens e.g. ["{{student_name}}"]
  isActive    Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  requestTypes       RequestType[]
  generatedDocuments GeneratedDocument[]

  @@map("document_templates")
}

// ─────────────────────────────────────────────────────
// REQUEST TYPE  (staff configures)
// ─────────────────────────────────────────────────────

model RequestType {
  id          Int     @id @default(autoincrement())
  name        String
  description String?
  icon        String? // react-icons key e.g. "RiPlaneLine"
  isActive    Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  documentTemplates DocumentTemplate[]
  requests          Request[]

  @@map("request_types")
}

// ─────────────────────────────────────────────────────
// REQUEST / PETITION  (student submits)
// ─────────────────────────────────────────────────────

model Request {
  id            Int           @id @default(autoincrement())
  studentId     Int
  requestTypeId Int?
  title         String
  description   String?       @db.Text
  formData      String?       @db.LongText  // JSON — values student filled in
  status        RequestStatus @default(PENDING)
  attachments   String?       @db.Text      // JSON array of file URLs

  // Advisor review
  advisorId      Int?
  advisorComment String?   @db.Text
  advisorAt      DateTime?

  // Staff review
  staffId      Int?
  staffComment String?   @db.Text
  staffAt      DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  student     Student      @relation(fields: [studentId], references: [id], onDelete: Cascade)
  requestType RequestType? @relation(fields: [requestTypeId], references: [id])

  @@map("requests")
}

// ─────────────────────────────────────────────────────
// GENERATED DOCUMENT
// ─────────────────────────────────────────────────────

model GeneratedDocument {
  id          Int     @id @default(autoincrement())
  templateId  Int
  studentId   Int
  generatedBy Int

  fileUrl       String?
  signedFileUrl String?
  signedBy      String?
  signedAt      DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  template DocumentTemplate @relation(fields: [templateId], references: [id])
  student  Student          @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@map("generated_documents")
}

// ─────────────────────────────────────────────────────
// EMAIL TEMPLATE
// ─────────────────────────────────────────────────────

model EmailTemplate {
  id        Int     @id @default(autoincrement())
  name      String
  subject   String
  body      String  @db.LongText
  variables String? @db.Text  // JSON
  isActive  Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("email_templates")
}

// ─────────────────────────────────────────────────────
// VISA RENEWAL & KKU INTERSERVICE
// ─────────────────────────────────────────────────────

model VisaRenewal {
  id            Int      @id @default(autoincrement())
  studentId     Int
  daysRemaining Int
  notifiedAt    DateTime @default(now())
  isResolved    Boolean  @default(false)
  resolvedAt    DateTime?

  student            Student             @relation(fields: [studentId], references: [id], onDelete: Cascade)
  interserviceChecks InterserviceCheck[]

  @@map("visa_renewals")
}

model InterserviceCheck {
  id          Int                @id @default(autoincrement())
  studentId   Int
  renewalId   Int?
  status      InterserviceStatus @default(NOT_SUBMITTED)
  referenceId String?
  notes       String?
  checkedAt   DateTime           @default(now())

  student Student      @relation(fields: [studentId], references: [id], onDelete: Cascade)
  renewal VisaRenewal? @relation(fields: [renewalId], references: [id])

  @@map("interservice_checks")
}

// ─────────────────────────────────────────────────────
// NOTIFICATION
// ─────────────────────────────────────────────────────

model Notification {
  id        Int              @id @default(autoincrement())
  userId    Int
  title     String
  message   String           @db.Text
  type      NotificationType @default(GENERAL)
  isRead    Boolean          @default(false)
  link      String?

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

// ─────────────────────────────────────────────────────
// AUDIT LOG
// ─────────────────────────────────────────────────────

model AuditLog {
  id        Int      @id @default(autoincrement())
  userId    Int
  action    String
  entity    String
  entityId  Int?
  before    String?  @db.LongText
  after     String?  @db.LongText
  ipAddress String?

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@map("audit_logs")
}
