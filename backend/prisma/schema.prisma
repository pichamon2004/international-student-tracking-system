generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────────────

enum Role {
  STUDENT
  ADVISOR
  STAFF
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum AcademicLevel {
  BACHELOR
  MASTER
  PHD
}

enum RegistrationStatus {
  PENDING_APPROVAL  // Phase 1: รอ Staff อนุมัติ
  REJECTED          // ถูกปฏิเสธใน Phase 1
  PHASE2_INCOMPLETE // Phase 2: กรอกข้อมูลยังไม่ครบ
  ACTIVE            // ลงทะเบียนครบแล้ว
}

enum VisaStatus {
  ACTIVE
  EXPIRED
  PENDING
  CANCELLED
}

enum RequestStatus {
  PENDING                // นักศึกษายื่นคำร้อง → Staff รับก่อน
  FORWARDED_TO_ADVISOR   // Staff ส่งให้อาจารย์พิจารณา
  ADVISOR_APPROVED       // อาจารย์อนุมัติ → กลับมาที่ Staff อนุมัติขั้นสุดท้าย
  ADVISOR_REJECTED       // อาจารย์ปฏิเสธ
  STAFF_APPROVED         // Staff อนุมัติขั้นสุดท้าย (สมบูรณ์)
  STAFF_REJECTED         // Staff ปฏิเสธ
  CANCELLED              // ยกเลิก
}

enum DocumentType {
  PASSPORT_COPY
  VISA_COPY
  TRANSCRIPT
  INSURANCE
  ENROLLMENT_CERTIFICATE
  PHOTO
  WORK_PERMIT
  OTHER
}

enum InterserviceStatus {
  NOT_SUBMITTED  // ยังไม่ได้ยื่นใน KKU Interservice
  PENDING        // ยื่นแล้ว รอดำเนินการ
  APPROVED       // อนุมัติแล้ว
  REJECTED       // ถูกปฏิเสธ
}

enum NotificationType {
  VISA_ALERT          // แจ้งเตือนวีซ่าใกล้หมดอายุ
  REGISTRATION        // แจ้งผลการลงทะเบียน
  REQUEST_UPDATE      // แจ้งผลคำร้อง
  DOCUMENT_REQUIRED   // แจ้งให้แนบเอกสาร
  GENERAL
}

// ─────────────────────────────────────────────────────
// USER & AUTH
// ─────────────────────────────────────────────────────

model User {
  id        Int       @id @default(autoincrement())
  email     String    @unique
  googleId  String?   @unique   // Google OAuth 2.0 (Prototype) / KKU SSO (ระบบจริง)
  name      String
  image     String?             // Profile picture URL จาก Google
  role      Role?               // null = ยังไม่ได้รับการกำหนด Role จาก Staff
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  student       Student?
  advisor       Advisor?
  auditLogs     AuditLog[]
  notifications Notification[]

  @@map("users")
}

// ─────────────────────────────────────────────────────
// STUDENT
// ─────────────────────────────────────────────────────

model Student {
  id        Int     @id @default(autoincrement())
  userId    Int     @unique
  studentId String? @unique  // kku_student_id (Staff กรอกให้ตอนกำหนด Role)

  // Personal Info (Phase 2 — Step 1)
  titleTh           String?
  firstNameTh       String?
  lastNameTh        String?
  titleEn           String?
  firstNameEn       String?
  lastNameEn        String?
  dateOfBirth       DateTime?
  gender            Gender?
  nationality       String?
  religion          String?

  // Contact
  email             String?
  phone             String?
  address           String?   @db.Text
  emergencyContact  String?
  emergencyPhone    String?
  emergencyRelation String?

  // Academic (Staff กรอกหลัง Phase 1 อนุมัติ)
  faculty            String?
  program            String?
  level              AcademicLevel?
  enrollmentDate     DateTime?
  expectedGraduation DateTime?
  academicStatus     String?         // Active, On Leave, Graduated
  scholarship        String?         // ทุนการศึกษา
  advisorId          Int?

  // Registration
  registrationStatus RegistrationStatus @default(PENDING_APPROVAL)
  registrationStep   Int                @default(1)   // Phase 2 step ที่ค้างอยู่ (1–6)
  rejectionReason    String?            @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user               User               @relation(fields: [userId], references: [id])
  advisor            Advisor?           @relation(fields: [advisorId], references: [id])
  passport           Passport?
  visas              Visa[]
  dependents         Dependent[]
  documents          Document[]
  requests           Request[]
  visaRenewals       VisaRenewal[]
  interserviceChecks InterserviceCheck[]
  generatedDocuments GeneratedDocument[]

  @@map("students")
}

// ─────────────────────────────────────────────────────
// ADVISOR
// ─────────────────────────────────────────────────────

model Advisor {
  id          Int     @id @default(autoincrement())
  userId      Int     @unique

  titleTh     String?
  firstNameTh String?
  lastNameTh  String?
  titleEn     String?
  firstNameEn String?
  lastNameEn  String?
  nationality String?
  phone       String?
  faculty     String?

  // Work Permit (เฉพาะอาจารย์ต่างชาติ — กรอกเองหลังล็อกอินครั้งแรก)
  workPermitNumber  String?
  workPermitIssue   DateTime?
  workPermitExpiry  DateTime?
  workPermitFileUrl String?

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user     User      @relation(fields: [userId], references: [id])
  students Student[]

  @@map("advisors")
}

// ─────────────────────────────────────────────────────
// PASSPORT
// ─────────────────────────────────────────────────────

model Passport {
  id             Int      @id @default(autoincrement())
  studentId      Int      @unique
  passportNumber String   @unique
  issuingCountry String
  issueDate      DateTime
  expiryDate     DateTime
  placeOfIssue   String?

  // OCR / MRZ Data (Phase 2 — Step 2)
  mrzLine1   String?
  mrzLine2   String?
  imageUrl   String?
  isVerified Boolean  @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@map("passports")
}

// ─────────────────────────────────────────────────────
// VISA
// ─────────────────────────────────────────────────────

model Visa {
  id             Int        @id @default(autoincrement())
  studentId      Int
  visaNumber     String?
  visaType       String     // ED, Non-B, Non-O, Tourist ฯลฯ
  status         VisaStatus @default(ACTIVE)
  issuingCountry String
  issuingPlace   String?
  issueDate      DateTime
  expiryDate     DateTime
  entries        String?    // Single, Multiple, Re-entry
  remarks        String?    @db.Text
  imageUrl       String?
  isCurrent      Boolean    @default(true)  // วีซ่าที่ใช้งานอยู่ปัจจุบัน

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@map("visas")
}

// ─────────────────────────────────────────────────────
// DEPENDENT (ผู้ติดตาม — Phase 2 Step 6)
// ─────────────────────────────────────────────────────

model Dependent {
  id           Int    @id @default(autoincrement())
  studentId    Int
  relationship String // Spouse, Child

  // Personal
  firstNameEn String
  lastNameEn  String
  firstNameTh String?
  lastNameTh  String?
  dateOfBirth DateTime
  gender      Gender
  nationality String

  // Passport
  passportNumber   String?
  passportExpiry   DateTime?
  passportImageUrl String?

  // Visa
  visaType     String?
  visaExpiry   DateTime?
  visaImageUrl String?
  visaStatus   VisaStatus @default(ACTIVE)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  student   Student    @relation(fields: [studentId], references: [id], onDelete: Cascade)
  documents Document[]

  @@map("dependents")
}

// ─────────────────────────────────────────────────────
// DOCUMENT
// ─────────────────────────────────────────────────────

model Document {
  id           Int          @id @default(autoincrement())
  studentId    Int?
  dependentId  Int?
  documentType DocumentType @default(OTHER)
  name         String
  description  String?
  fileUrl      String
  fileType     String       // pdf, jpg, png ฯลฯ
  fileSize     Int          // bytes
  uploadedBy   Int          // userId ของผู้อัปโหลด

  uploadedAt DateTime @default(now())
  updatedAt  DateTime @updatedAt

  student   Student?   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  dependent Dependent? @relation(fields: [dependentId], references: [id], onDelete: Cascade)

  @@map("documents")
}

// ─────────────────────────────────────────────────────
// REQUEST / PETITION (คำร้อง)
// ─────────────────────────────────────────────────────

model Request {
  id          Int           @id @default(autoincrement())
  studentId   Int
  type        String        // visa_extension, leave, name_change ฯลฯ
  title       String
  description String?       @db.Text
  status      RequestStatus @default(PENDING)
  attachments String?       @db.Text  // JSON array of file URLs

  // Advisor Review
  advisorId      Int?
  advisorComment String?   @db.Text
  advisorAt      DateTime?

  // Staff Review
  staffId      Int?
  staffComment String?   @db.Text
  staffAt      DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@map("requests")
}

// ─────────────────────────────────────────────────────
// PDF DOCUMENT TEMPLATE & GENERATED DOCUMENT
// ─────────────────────────────────────────────────────

model DocumentTemplate {
  id          Int     @id @default(autoincrement())
  name        String
  description String?
  content     String  @db.LongText  // Template พร้อม Placeholder เช่น {{student_name}}
  isActive    Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  generatedDocuments GeneratedDocument[]

  @@map("document_templates")
}

model GeneratedDocument {
  id         Int    @id @default(autoincrement())
  templateId Int
  studentId  Int
  generatedBy Int   // Staff userId

  fileUrl       String?   // PDF ที่ Generate แล้ว
  signedFileUrl String?   // PDF ที่ลงนามแล้ว (อัปโหลดกลับ)
  signedBy      String?
  signedAt      DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  template DocumentTemplate @relation(fields: [templateId], references: [id])
  student  Student          @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@map("generated_documents")
}

// ─────────────────────────────────────────────────────
// EMAIL TEMPLATE (UC23 / FR13)
// ─────────────────────────────────────────────────────

model EmailTemplate {
  id        Int     @id @default(autoincrement())
  name      String
  subject   String
  body      String  @db.LongText  // Template พร้อม Placeholder เช่น {{student_name}}
  variables String? @db.Text      // JSON: [{key: "student_name", description: "ชื่อนักศึกษา"}]
  isActive  Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("email_templates")
}

// ─────────────────────────────────────────────────────
// VISA RENEWAL & KKU INTERSERVICE
// ─────────────────────────────────────────────────────

model VisaRenewal {
  id            Int      @id @default(autoincrement())
  studentId     Int
  daysRemaining Int      // 60, 30, หรือ 7 วัน
  notifiedAt    DateTime @default(now())
  isResolved    Boolean  @default(false)
  resolvedAt    DateTime?

  student            Student             @relation(fields: [studentId], references: [id], onDelete: Cascade)
  interserviceChecks InterserviceCheck[]

  @@map("visa_renewals")
}

model InterserviceCheck {
  id          Int                @id @default(autoincrement())
  studentId   Int
  renewalId   Int?
  status      InterserviceStatus @default(NOT_SUBMITTED)
  referenceId String?            // Reference ID จาก KKU Interservice
  notes       String?
  checkedAt   DateTime           @default(now())

  student Student      @relation(fields: [studentId], references: [id], onDelete: Cascade)
  renewal VisaRenewal? @relation(fields: [renewalId], references: [id])

  @@map("interservice_checks")
}

// ─────────────────────────────────────────────────────
// NOTIFICATION
// ─────────────────────────────────────────────────────

model Notification {
  id        Int              @id @default(autoincrement())
  userId    Int
  title     String
  message   String           @db.Text
  type      NotificationType @default(GENERAL)
  isRead    Boolean          @default(false)
  link      String?          // Deep link ไปหน้าที่เกี่ยวข้อง

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

// ─────────────────────────────────────────────────────
// AUDIT LOG
// ─────────────────────────────────────────────────────

model AuditLog {
  id        Int      @id @default(autoincrement())
  userId    Int
  action    String   // CREATE, UPDATE, DELETE, LOGIN, APPROVE ฯลฯ
  entity    String   // Student, Visa, Document, Request ฯลฯ
  entityId  Int?
  before    String?  @db.LongText  // JSON: ข้อมูลก่อนเปลี่ยน
  after     String?  @db.LongText  // JSON: ข้อมูลหลังเปลี่ยน
  ipAddress String?

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@map("audit_logs")
}
