DATABASE_URL="mysql://user:password@localhost:3306/ist_db"
JWT_SECRET="your-super-secret-jwt-key-change-this"
JWT_EXPIRES_IN="7d"
PORT=4000
NODE_ENV=development
FRONTEND_URL="http://localhost:3000"
BACKEND_URL="http://localhost:4000"
PYTHON_SERVICE_URL="http://localhost:5000"
UPLOAD_DIR="./uploads"

# Google OAuth — สร้างได้ที่ https://console.cloud.google.com/
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# Cloudflare R2 — สร้าง API Token ได้ที่ Cloudflare Dashboard → R2 → Manage API Tokens
R2_ACCOUNT_ID="your-cloudflare-account-id"
R2_ACCESS_KEY_ID="your-r2-access-key-id"
R2_SECRET_ACCESS_KEY="your-r2-secret-access-key"
R2_BUCKET_NAME="ist-documents"
R2_PUBLIC_URL="https://your-bucket.your-subdomain.r2.dev"
